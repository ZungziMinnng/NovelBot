# API provider defaults
# OpenAI-compatible providers include OpenAI, DeepSeek, AiHubMix, and similar relay APIs.
OPENAI_API_KEY=your_openai_compatible_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini native API
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Anthropic native API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Backward-compatible AiHubMix variables are still accepted by app.config,
# but new installs should prefer OPENAI_* / GEMINI_* / ANTHROPIC_* above.
# AIHUBMIX_API_KEY=
# AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# Default model configuration
DEFAULT_WRITER_MODEL=gpt-4o
DEFAULT_FAST_MODEL=gpt-4o-mini

# Optional per-Agent model overrides. Leave blank to use the defaults above.
AGENT_WRITER_MODEL=
AGENT_CRITIC_MODEL=
AGENT_MEMORY_MODEL=
AGENT_OUTLINE_MODEL=
AGENT_CHARACTER_MODEL=
AGENT_ORCHESTRATOR_MODEL=
AGENT_REVIEW_MODEL=

# Data paths
DATA_DIR=./data
DATABASE_URL=sqlite+aiosqlite:///./data/novelbot.db
CHROMA_PATH=./data/chroma

# Network proxy. Use the NOVELBOT_ prefix to avoid OS-level proxy conflicts.
NOVELBOT_HTTPS_PROXY=
NOVELBOT_HTTP_PROXY=

# App settings
APP_TITLE=NovelBot
DEBUG=true
ENABLE_REVIEW=false
REVIEW_INTERVAL=10
